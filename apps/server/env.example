# ==============================================
# SERVER CONFIGURATION
# ==============================================
# This file is for local development (`bun run dev`).
# For compiled executable deployments, use `settings.json` with:
#   boot.mode = "compiled"
# In compiled mode, config env var overrides are ignored by design.
# Optional boot config path override: `ERAGEAR_BOOT_CONFIG_PATH=/absolute/or/relative/settings.json`
PORT=3000
NODE_ENV=development
# DOMAIN=dng.ngrok.app # Domain public n?u có, dùng cho better-auth check origin

# ==============================================
# AUTHENTICATION (Better Auth)
# ==============================================
# REQUIRED: Secret key required for authentication encryption. 
# Generate one using `openssl rand -base64 32`
AUTH_SECRET=change_me_in_production_with_32_chars_min
# Base URL of the auth server (must match your actual running URL)
AUTH_BASE_URL=http://localhost:3000
# Comma-separated list of trusted origins for CORS and Auth.
# Include the Expo app scheme for native auth callbacks. In local Expo dev, keep exp:// too.
AUTH_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173,eragear-code-copilot://,exp://
# Comma-separated list of trusted reverse-proxy source IPs
AUTH_TRUSTED_PROXY_IPS=127.0.0.1,::1
# Strict CORS origin check (must be true in production)
CORS_STRICT_ORIGIN=false

# Auth Admin Bootstrap (Optional - for first run)
# AUTH_ADMIN_USERNAME=admin
# AUTH_ADMIN_PASSWORD=secure_password
# AUTH_ADMIN_EMAIL=admin@example.com

# API Key Settings
AUTH_ALLOW_SIGNUP=false
AUTH_BOOTSTRAP_API_KEY=true
AUTH_BOOTSTRAP_ENSURE_DEFAULTS_TTL_MS=1800000
AUTH_BOOTSTRAP_CACHE_MAX_USERS=10000
AUTH_BOOTSTRAP_INFLIGHT_MAX_USERS=2000
AUTH_API_KEY_PREFIX=sk_
AUTH_API_KEY_RATE_LIMIT_ENABLED=true
AUTH_API_KEY_RATE_LIMIT_TIME_WINDOW_MS=60000
AUTH_API_KEY_RATE_LIMIT_MAX_REQUESTS=3000
# Require Cloudflare Access headers/JWT for WebSocket (/trpc) handshake
AUTH_REQUIRE_CLOUDFLARE_ACCESS=false
# Service token verification (set both when AUTH_REQUIRE_CLOUDFLARE_ACCESS=true)
# AUTH_CLOUDFLARE_ACCESS_CLIENT_ID=
# AUTH_CLOUDFLARE_ACCESS_CLIENT_SECRET=
# JWT assertion verification (set all three when AUTH_REQUIRE_CLOUDFLARE_ACCESS=true)
# AUTH_CLOUDFLARE_ACCESS_JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# AUTH_CLOUDFLARE_ACCESS_JWT_AUDIENCE=
# AUTH_CLOUDFLARE_ACCESS_JWT_ISSUER=

# Database Paths (Optional Overrides)
# AUTH_DB_PATH=.eragear/auth.db

# ==============================================
# SECURITY & COMMAND ALLOWLISTS (REQUIRED)
# ==============================================
# Strict allowlists for security. Wildcards (*) are NOT supported.
# Canonical format is JSON command policies.
# Legacy ALLOWED_*_COMMANDS keys are deprecated and ignored.
ALLOWED_AGENT_COMMAND_POLICIES=[{"command":"/usr/local/bin/codex","allowAnyArgs":true},{"command":"C:\\\\Program Files\\\\Codex\\\\codex.exe","allowAnyArgs":true}]
ALLOWED_TERMINAL_COMMAND_POLICIES=[{"command":"/bin/sh","allowAnyArgs":true},{"command":"C:\\\\Windows\\\\System32\\\\cmd.exe","allowAnyArgs":true}]
ALLOWED_ENV_KEYS=NODE_ENV,API_KEY,DEBUG,PATH
# Dangerous ACP client tools are opt-in. Keep disabled unless you explicitly trust the agent/runtime boundary.
ACP_ENABLE_FS_WRITE=false
ACP_ENABLE_TERMINAL=false

# ==============================================
# WEBSOCKET & SERVER SETTINGS
# ==============================================
WS_PORT=3000
WS_HOST=0.0.0.0
WS_HEARTBEAT_INTERVAL_MS=30000
WS_MAX_PAYLOAD_BYTES=16777216

# ==============================================
# SESSION & LIMITS
# ==============================================
SESSION_IDLE_TIMEOUT_MS=600000
SESSION_BUFFER_LIMIT=500
SESSION_LIST_PAGE_MAX_LIMIT=500
SESSION_MESSAGES_PAGE_MAX_LIMIT=200
MAX_TOKENS=8192
DEFAULT_MODEL=
MESSAGE_CONTENT_MAX_BYTES=2097152
MESSAGE_PARTS_MAX_BYTES=4194304
ACP_NDJSON_MAX_LINE_BYTES=1048576
ACP_NDJSON_MAX_BUFFERED_BYTES=4194304

# ==============================================
# ACP SUPERVISOR AUTOPILOT
# ==============================================
# Enable server-side supervisor loop. Requires SUPERVISOR_MODEL and a provider API key.
SUPERVISOR_ENABLED=false
# Stronger DeepSeek model for schema-heavy supervisor decisions. Requires DEEPSEEK_API_KEY.
SUPERVISOR_MODEL=deepseek/deepseek-reasoner
# In compiled mode this may also be set in settings.json boot.DEEPSEEK_API_KEY.
DEEPSEEK_API_KEY=
SUPERVISOR_DECISION_TIMEOUT_MS=30000
SUPERVISOR_DECISION_MAX_ATTEMPTS=2
SUPERVISOR_MAX_RUNTIME_MS=1800000
SUPERVISOR_MAX_REPEATED_PROMPTS=20

# Optional web research. Keep disabled unless an Exa key is configured.
SUPERVISOR_WEB_SEARCH_PROVIDER=none
# SUPERVISOR_WEB_SEARCH_PROVIDER=exa
# EXA_API_KEY is also accepted as an alias for SUPERVISOR_WEB_SEARCH_API_KEY.
# EXA_API_KEY=
# SUPERVISOR_WEB_SEARCH_API_KEY=

# Optional local memory through Obsidian CLI.
SUPERVISOR_MEMORY_PROVIDER=none
SUPERVISOR_OBSIDIAN_COMMAND=obsidian
SUPERVISOR_OBSIDIAN_VAULT=
SUPERVISOR_OBSIDIAN_BLUEPRINT_PATH=
SUPERVISOR_OBSIDIAN_LOG_PATH=
SUPERVISOR_OBSIDIAN_SEARCH_PATH=Project
SUPERVISOR_OBSIDIAN_SEARCH_LIMIT=3
SUPERVISOR_OBSIDIAN_TIMEOUT_MS=5000

# ==============================================
# LOGGING
# ==============================================
LOG_BUFFER_LIMIT=2000
LOG_LEVEL=info
LOG_OUTPUT_FORMAT=text
LOG_FLUSH_INTERVAL_MS=250
LOG_FILE_ENABLED=true
# LOG_RETENTION_DAYS=7

# ==============================================
# BACKGROUND TASKS
# ==============================================
BACKGROUND_ENABLED=true
BACKGROUND_TICK_MS=1000
BACKGROUND_TASK_TIMEOUT_MS=30000
BACKGROUND_SESSION_CLEANUP_INTERVAL_MS=15000
BACKGROUND_CACHE_PRUNE_INTERVAL_MS=300000
BACKGROUND_STORAGE_MAINTENANCE_INTERVAL_MS=300000

# ==============================================
# SQLITE PERFORMANCE
# ==============================================
# Enable worker thread mainly for High Concurrency (Default: true)
STORAGE_WORKER_ENABLED=true
STORAGE_BUSY_TIMEOUT_MS=10000
STORAGE_BUSY_MAX_RETRIES=5
STORAGE_WAL_CHECKPOINT_INTERVAL_MS=300000
STORAGE_MAX_DB_SIZE_MB=2048
STORAGE_RETENTION_HOT_DAYS=30
