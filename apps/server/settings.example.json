{
  "$schema": "./settings.schema.json",
  "boot": {
    "mode": "compiled",
    "WS_PORT": 3000,
    "WS_HOST": "0.0.0.0",
    "WS_AUTH_TIMEOUT_MS": 30000,
    "WS_SESSION_REVALIDATE_INTERVAL_MS": 60000,
    "AUTH_SECRET": "change_me_in_production_with_32_chars_min",
    "LOG_LEVEL": "info",
    "MAX_TOKENS": 8192,
    "DEFAULT_MODEL": "",
    "AUTH_TRUSTED_ORIGINS": ["http://localhost:3000", "http://localhost:5173", "eragear-code-copilot://", "exp://"],
    "AUTH_REQUIRE_CLOUDFLARE_ACCESS": false,
    "ALLOWED_AGENT_COMMAND_POLICIES": [
      { "command": "/usr/local/bin/codex", "allowAnyArgs": true },
      { "command": "C:\\Program Files\\Codex\\codex.exe", "allowAnyArgs": true }
    ],
    "ALLOWED_TERMINAL_COMMAND_POLICIES": [
      { "command": "/bin/sh", "allowAnyArgs": true },
      { "command": "C:\\Windows\\System32\\cmd.exe", "allowAnyArgs": true }
    ],
    "ALLOWED_ENV_KEYS": ["NODE_ENV", "API_KEY", "DEBUG", "PATH"]
  }
}
