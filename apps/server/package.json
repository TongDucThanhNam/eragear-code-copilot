    "@eragear-code-copilot/env": "workspace:*",
    "@repo/shared": "workspace:*",
    "@trpc/server": "^11.8.1",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "hono": "^4.8.2",
    "ws": "^8.19.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eragear-code-copilot/config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/ws": "^8.18.1",
    "tsdown": "^0.16.5",
    "typescript": "catalog:"
  }
