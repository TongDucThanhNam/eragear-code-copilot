{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown && bun run ui:build",
    "check-types": "tsc -b",
    "compile": "bun run ui:build && bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile dist/server",
    "dev": "NODE_ENV=development bun run --hot src/index.ts",
    "start": "bun run dist/index.js",
    "ui:build": "bun build ./ui/client.tsx --outfile ./public/client.js --target browser --format esm --minify && cp ./src/transport/http/ui/styles.css ./public/styles.css"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.13.1",
    "@eragear-code-copilot/auth": "workspace:*",
    "@eragear-code-copilot/db": "workspace:*",
    "@eragear-code-copilot/env": "workspace:*",
    "@hono/node-server": "^1.17.1",
    "@hono/react-renderer": "^1.0.1",
    "@repo/shared": "workspace:*",
    "@trpc/server": "^11.8.1",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "hono": "^4.8.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ws": "^8.19.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eragear-code-copilot/config": "workspace:*",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/bun": "catalog:",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.2",
    "vite": "^7.3.1",
    "tsdown": "^0.16.5",
    "typescript": "catalog:"
  }
}
