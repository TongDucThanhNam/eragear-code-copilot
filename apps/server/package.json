{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown && bun run ui:build",
    "check": "bun run check-types && bunx biome check src --error-on-warnings && bun run test",
    "check:ci": "bun run check-types && bunx biome check src --error-on-warnings && bun test src",
    "check:quick": "bun run check-types && bunx biome check src --error-on-warnings",
    "check-types": "tsc -b --noEmit",
    "compile": "bun run ./scripts/compile.ts",
    "db:generate": "bunx drizzle-kit generate --config drizzle.config.ts",
    "dev": "bun run ./scripts/dev.ts",
    "lint": "bunx biome lint --diagnostic-level=error src",
    "lint:strict": "bunx biome lint --diagnostic-level=error --error-on-warnings src",
    "lint:fix": "bunx biome check --write .",
    "lint:full": "bunx biome check .",
    "smoke:auth-dashboard": "bun run ./scripts/smoke-auth-dashboard.ts",
    "start": "bun run build && bun run dist/index.mjs",
    "start:dist": "bun run dist/index.mjs",
    "test:auth-dashboard": "bun test ./src/platform/auth/auth-dashboard.integration.test.ts ./src/transport/http/utils/response-headers.test.ts",
    "test:blockers": "ALLOWED_AGENT_COMMAND_POLICIES='[{\"command\":\"/usr/bin/env\",\"allowAnyArgs\":true}]' ALLOWED_TERMINAL_COMMAND_POLICIES='[{\"command\":\"/usr/bin/env\",\"allowAnyArgs\":true}]' ALLOWED_ENV_KEYS='PATH,HOME,SHELL,USER,TMPDIR,TMP,TEMP' bun test src/platform/acp/tool-calls.test.ts src/modules/session/application/subscribe-session-events.service.test.ts src/modules/ai/application/cancel-prompt.service.test.ts src/modules/tooling/application/code-context.service.test.ts src/modules/tooling/application/contracts/tooling.contract.test.ts src/shared/utils/editor-buffer.util.test.ts",
    "ui": "bun run ui:watch",
    "ui:build": "bun run ./scripts/build-dashboard-assets.ts",
    "ui:watch": "bun run ./scripts/watch-dashboard-assets.ts",
    "test": "bun test src"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "0.15.0",
    "@eragear-code-copilot/env": "workspace:*",
    "@hono/react-renderer": "^1.0.1",
    "@repo/shared": "workspace:*",
    "@trpc/server": "^11.8.1",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.8.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ws": "^8.19.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eragear-code-copilot/config": "workspace:*",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/bun": "catalog:",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.2",
    "drizzle-kit": "^0.31.8",
    "vite": "^7.3.1",
    "tsdown": "^0.16.5",
    "typescript": "catalog:"
  }
}
