{
  "$schema": "https://biomejs.dev/schemas/2.3.11/schema.json",
  "extends": [
    "ultracite/biome/core",
    "ultracite/biome/react",
    "ultracite/biome/remix"
  ],
  "files": {
    "includes": ["!/node_modules", "!/dist", "!/public/dashboard", "!/.eragear"]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "complexity": {
        "noExcessiveCognitiveComplexity": {
          "level": "warn",
          "options": { "maxAllowedComplexity": 25 }
        }
      }
    }
  },
  "overrides": [
    {
      "includes": ["src/modules/**/domain/**/*.ts"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "**/infra/**",
                      "**/transport/**",
                      "@/infra/**",
                      "@/transport/**"
                    ],
                    "message": "Domain must not import from transport or infra."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/modules/**/application/**/*.ts"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["**/transport/**", "@/transport/**"],
                    "message": "Application must not import from transport."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/transport/**/*.ts"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "**/domain/**",
                      "**/infra/**",
                      "@/domain/**",
                      "@/infra/**"
                    ],
                    "message": "Transport should not import from domain or infra."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/infra/**/*.ts"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["**/transport/**", "@/transport/**"],
                    "message": "Infra must not import from transport."
                  }
                ]
              }
            }
          }
        }
      }
    }
  ]
}
