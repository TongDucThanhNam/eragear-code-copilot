{
  "name": "eragear-code-copilot",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@types/bun": "^1.3.4",
      "better-auth": "^1.4.9",
      "@better-auth/expo": "^1.4.9"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @eragear-code-copilot/db db:push",
    "db:studio": "turbo -F @eragear-code-copilot/db db:studio",
    "db:generate": "turbo -F @eragear-code-copilot/db db:generate",
    "db:migrate": "turbo -F @eragear-code-copilot/db db:migrate"
  },
  "dependencies": {
    "@better-auth/kysely-adapter": "^1.5.0-beta.9",
    "@eragear-code-copilot/env": "workspace:*",
    "better-sqlite3": "^12.6.2",
    "dotenv": "catalog:",
    "kysely": "^0.28.10",
    "sql.js": "^1.13.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@eragear-code-copilot/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.6.3",
    "typescript": "catalog:",
    "ultracite": "7.0.11"
  },
  "packageManager": "bun@1.3.0"
}
