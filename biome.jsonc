{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": [
    "ultracite/biome/core",
    "ultracite/biome/react",
    "ultracite/biome/remix"
  ],
  "files": {
    "includes": [
      "!/node_modules",
      "!/apps/web/src/components/ai-elements",
      "!/apps/web/src/components/ui"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "complexity": {
        "noExcessiveCognitiveComplexity": {
          "level": "warn",
          "options": { "maxAllowedComplexity": 25 }
        }
      }
    }
  },
  "overrides": [
    {
      "includes": ["apps/server/src/modules/**/domain/**/*.ts"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "**/infra/**",
                      "**/transport/**",
                      "@/infra/**",
                      "@/transport/**"
                    ],
                    "message": "Domain must not import from transport or infra."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["apps/server/src/modules/**/application/**/*.ts"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["**/transport/**", "@/transport/**"],
                    "message": "Application must not import from transport."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["apps/server/src/transport/**/*.ts"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "**/domain/**",
                      "**/infra/**",
                      "@/domain/**",
                      "@/infra/**"
                    ],
                    "message": "Transport should not import from domain or infra."
                  }
                ]
              }
            }
          }
        }
      }
    }
  ]
}
